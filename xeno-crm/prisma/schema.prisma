generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Customer {
  id         String   @id @default(cuid())
  name       String
  email      String   @unique
  totalSpent Float    @default(0)
  createdAt  DateTime @default(now())
}

model Campaign {
  id         String   @id @default(cuid())
  name       String
  message    String
  audience   String
  createdAt  DateTime @default(now())
}